{
  "build": {
    "content": [
      {
        "files": [
          "*.md",
          "toc.yml",
          "reference/*.md"
        ],
        "exclude": [
          "README.md"
        ]
      }
    ],
    "resource": [
      {
        "src": "..",
        "files": [
          "media/**"
        ],
        "dest": "media"
      }
    ],
    "overwrite": [],
    "dest": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern"
    ],
    "postProcessors": [],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false,
    "globalMetadata": {
      "_appTitle": "Kite Documentation",
      "_appName": "Kite",
      "_appFooter": "Kite - A specification-driven development toolkit",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/Karnonson/kite",
        "branch": "main"
      }
    }
  }
}

