// Kite Dev Container — generated by `install-devcontainer.sh`.
// Docs: docs/devcontainer.md
{
	"name": "Kite Workspace",
	"build": {
		"dockerfile": "Dockerfile",
		"context": "."
	},
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
			"version": "latest",
			"moby": true
		}
	},
	"containerUser": "codespace",
	"updateRemoteUserUID": true,
	"remoteEnv": {
		// Default installs Kite from the upstream repo until kite-cli is published to PyPI.
		// Pin to a tag/SHA: "KITE_INSTALL_SPEC": "git+https://github.com/Karnonson/kite.git@v0.7.2"
		// Once on PyPI, switch to: "KITE_INSTALL_SPEC": "kite-cli" (and optionally set KITE_VERSION).
		"KITE_VERSION": "",
		"KITE_INSTALL_SPEC": "git+https://github.com/Karnonson/kite.git@main",
		"KITE_PNPM_VERSION": "10.10.0",
		"KITE_DEFAULT_INTEGRATION": "copilot"
	},
	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"postStartCommand": "bash .devcontainer/post-start.sh",
	"customizations": {
		"vscode": {
			"extensions": [
				"GitHub.copilot",
				"GitHub.copilot-chat",
				"ms-python.python",
				"ms-azuretools.vscode-docker"
			],
			"settings": {
				"chat.promptFilesRecommendations": {
					"kite.constitution": true,
					"kite.specify": true,
					"kite.plan": true,
					"kite.tasks": true,
					"kite.implement": true
				}
			}
		}
	}
}
