// Kite Dev Container — generated by `install-devcontainer.sh`.
// Docs: docs/devcontainer.md
{
	"name": "Kite Workspace",
	"build": {
		"dockerfile": "Dockerfile",
		"context": "."
	},
	"remoteUser": "codespace",
	"updateRemoteUserUID": false,
	"otherPortsAttributes": {
		"onAutoForward": "ignore"
	},
	"remoteEnv": {
		"KITE_DEV_ENV": "1",
		// Default installs Kite from the upstream repo until kite-cli is published to PyPI.
		// Pin to a tag/SHA: "KITE_INSTALL_SPEC": "git+https://github.com/Karnonson/kite.git@v0.7.2"
		// Once on PyPI, switch to: "KITE_INSTALL_SPEC": "kite-cli" (and optionally set KITE_VERSION).
		"KITE_VERSION": "",
		"KITE_INSTALL_SPEC": "git+https://github.com/Karnonson/kite.git@main",
		"KITE_PNPM_VERSION": "10.10.0",
		"KITE_DEFAULT_INTEGRATION": "copilot"
	},
	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"postStartCommand": "bash .devcontainer/post-start.sh"
}
